# ===== Model =====
ARK_API_KEY=your_dashscope_api_key
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen-plus
SUPERVISOR_MODEL=qwen-plus
GRADE_MODEL=qwen-plus
EMBEDDER=text-embedding-v1
MAX_TOKENS=8192
TRUNCATE_STRATEGY=end

# ===== Auth =====
JWT_SECRET=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== Database =====
# Local PyCharm / Conda run: docker-compose maps MySQL to localhost:3307.
DATABASE_URL=mysql+pymysql://root:password@localhost:3307/agent_chat

# If API runs inside docker compose full profile, use:
# DATABASE_URL=mysql+pymysql://root:password@mysql:3306/agent_chat

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=ragent
REDIS_CACHE_TTL_SECONDS=300

# ===== Milvus =====
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION=embeddings_collection
MILVUS_SEARCH_TOP_K=20
MILVUS_VECTOR_DIM=1536

# ===== Neo4j =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_QUERY_TIMEOUT=1.5

# ===== Rerank =====
RERANK_MODEL=qwen3-rerank
RERANK_BINDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
RERANK_API_KEY=your_dashscope_api_key
RERANK_TOP_K=10

# ===== Retrieval Weights =====
RRF_WEIGHT_DENSE=0.4
RRF_WEIGHT_SPARSE=0.3
RRF_WEIGHT_GRAPH=0.3
RRF_WEIGHT_VISUAL=0.15

# ===== Web Search / Tools Optional =====
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
AMAP_WEATHER_API=https://restapi.amap.com/v3/weather/weatherInfo
AMAP_API_KEY=

# ===== Multimodal / MinIO =====
LAYOUT_ANALYSIS_ENABLED=true
VLM_MODEL=qwen-vl-plus
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ragent-media

# ===== Semantic Cache =====
CACHE_ENABLED=true
CACHE_SIMILARITY_THRESHOLD=0.95
CACHE_TTL_SECONDS=86400

# ===== Model Routing =====
MODEL_TURBO=qwen-turbo
MODEL_MAX=qwen-max
DATA_ANALYST_MODEL=qwen-plus
CONTEXT_PRUNE_RATIO=0.6

# ===== Graph / Entity Resolution =====
ENTITY_SIM_THRESHOLD=0.75

# ===== Query Profiler =====
QUERY_PROFILER_USE_EMBEDDING=true
WEIGHT_MATRIX_CONFIG=config/weight_matrix.yaml

# ===== Observability =====
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
METRICS_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===== Load Monitor =====
LOAD_MONITOR_WINDOW=10
LOAD_WARNING_QPS=50
LOAD_CRITICAL_QPS=100
